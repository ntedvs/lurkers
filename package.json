{
  "name": "lurkers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "typecheck": "wrangler types && tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply lurkers --local",
    "db:migrate": "wrangler d1 migrations apply lurkers --remote"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "wrangler": "4.94.0"
  }
}
